# Copy sang .env trên VPS (cùng thư mục project)
# cp deploy/env.production.example .env  → điền secret thật

NODE_ENV=production
PORT=3001
APP_URL=https://pro.agi.vn

# Auth qua PHP bridge (MySQL localhost trên VPS)
AUTH_BRIDGE_URL=http://127.0.0.1/api/platform

JWT_SECRET=change-me-strong-secret-match-config-local-php
JWT_EXPIRES_IN=7d
SIGNUP_BONUS_CREDITS=1000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

GOMMO_API_BASE_URL=https://v2.api.gommo.net
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo
GOMMO_API_DOMAIN=vmedia.ai
GOMMO_ACCESS_TOKEN=

TOPUP_MIN_VND=10000
TOPUP_MAX_VND=20000000
TOPUP_CREDITS_PER_VND=1
ALLOW_MOCK_TOPUP=false

# Pay2S Production
PAY2S_SANDBOX=false
PAY2S_PARTNER_CODE=
PAY2S_ACCESS_KEY=
PAY2S_SECRET_KEY=
PAY2S_PARTNER_NAME=TOC AI
PAY2S_BANK_ACCOUNT=
PAY2S_BANK_ID=MBB
PAY2S_IPN_URL=https://pro.agi.vn/api/pay2s/ipn
PAY2S_REDIRECT_URL=https://pro.agi.vn/pricing
