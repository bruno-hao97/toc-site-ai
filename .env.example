# Gommo upstream (proxy server)
GOMMO_API_BASE_URL=https://v2.api.gommo.net
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo
# Merchant token — server Railway dùng để sendBalances sau PayOS webhook
GOMMO_ACCESS_TOKEN=
GOMMO_API_DOMAIN=vmedia.ai

# Server (Railway tự set PORT)
PORT=3001

# App URL (frontend public)
APP_URL=https://pro.agi.vn

# Platform auth (JWT) — đổi secret trên production
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
SIGNUP_BONUS_CREDITS=1000

# MySQL (VPS) — điền thật trong .env, không commit
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# Khi MySQL chỉ mở localhost trên VPS — proxy auth qua PHP bridge
# Local dev:
AUTH_BRIDGE_URL=http://pro.agi.vn/api/platform
# Production trên cùng VPS (nhanh hơn):
# AUTH_BRIDGE_URL=http://127.0.0.1/api/platform
#
# Deploy VPS: xem deploy/README.md — cần chạy Node API + nginx proxy /api

# Topup: quy đổi VND → credit
TOPUP_MIN_VND=10000
TOPUP_MAX_VND=20000000
TOPUP_CREDITS_PER_VND=1

# Pay2S (server-side only — điền key thật trong .env, không commit)
# Sandbox: PAY2S_SANDBOX=true + key từ my.pay2s.vn → Môi trường thử nghiệm
PAY2S_SANDBOX=true
PAY2S_PARTNER_CODE=
PAY2S_ACCESS_KEY=
PAY2S_SECRET_KEY=
PAY2S_PARTNER_NAME=LN AI
PAY2S_BANK_ACCOUNT=99999999
PAY2S_BANK_ID=ACB
# Production: bỏ PAY2S_SANDBOX hoặc =false, đổi bank thật + key Production
# PAY2S_API_CREATE_URL=https://payment.pay2s.vn/v1/gateway/api/create
# IPN phải là HTTPS công khai (Pay2S gọi về sau khi thanh toán)
PAY2S_IPN_URL=https://pro.agi.vn/api/pay2s/ipn
PAY2S_REDIRECT_URL=https://pro.agi.vn/pricing
