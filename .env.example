# Gommo upstream (proxy server)
GOMMO_API_BASE_URL=https://v2.api.gommo.net
GOMMO_AUTH_BASE_URL=https://api.gommo.net
GOMMO_AUTH_PATH=/api/apps/go-mmo
# Merchant token — server Railway dùng để sendBalances sau PayOS webhook
GOMMO_ACCESS_TOKEN=
GOMMO_API_DOMAIN=vmedia.ai

# Server (Railway tự set PORT)
PORT=3001

# App URL (frontend Vercel)
APP_URL=https://trungtamai.vn

# Topup: quy đổi VND → credit
TOPUP_MIN_VND=10000
TOPUP_MAX_VND=20000000
TOPUP_CREDITS_PER_VND=1

# PayOS (server-side only — điền key thật trong .env, không commit)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
# Webhook URL công khai trên Railway
PAYOS_WEBHOOK_URL=https://api.trungtamai.vn/api/payos/webhook
